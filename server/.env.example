PORT=4000
# Uma URL ou várias separadas por vírgula (URL exata do front em produção)
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (ex.: Neon — ver README na raiz do projeto)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# String longa e aleatória (não commitar o .env real)
JWT_SECRET="troque-por-uma-string-longa-e-secreta"

# Formulário de contato (opcional em dev — sem SMTP, grava no console da API)
CONTACT_TO_EMAIL=coopers@coopers.pro
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=coopers@coopers.pro
